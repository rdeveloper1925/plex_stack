# --- Identity / paths ---
PUID=1000
PGID=1000
TZ=America/New_York
MEDIA_ROOT=/your/custom/media/path
CONFIG_ROOT=/your/custom/config/path

# --- PIA VPN (Gluetun) ---
OPENVPN_USER=p1234567
OPENVPN_PASSWORD=your_pia_password
# Non-US regions with port forwarding. Gluetun uses PORT_FORWARD_ONLY=on in compose.
SERVER_REGIONS=Netherlands,CA Toronto,Switzerland
VPN_PORT_FORWARDING=on

# --- Network / access ---
# Private IP for admin UIs (Tailscale or LAN). Jellyfin is NOT bound here — use Cloudflare Tunnel.
BIND_IP=100.x.x.x
# Gluetun firewall allowlists (comma-separate multiple CIDRs in LAN_SUBNET)
LAN_SUBNET=192.168.1.0/24,100.64.0.0/10
DOCKER_SUBNET=10.0.0.0/8

# --- Jellyfin ---
# Public Jellyfin URL (Cloudflare Tunnel hostname on the deploy host)
JELLYFIN_PUBLISHED_SERVER_URL=https://movies.example.org

# --- qBittorrent ---
WEBUI_PORT=8080

# --- Prowlarr ---
PROWLARR_PORT=9696
