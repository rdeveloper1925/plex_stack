# Copy to ${CONFIG_ROOT}/gluetun/iptables/post-rules.txt on the deploy host.
# Required when Gluetun runs with network_mode: host so Tailscale keeps working.
# Do NOT add 100.64.0.0/10 to LAN_SUBNET / FIREWALL_OUTBOUND_SUBNETS.
iptables -I INPUT 1 -i tailscale0 -j ACCEPT
iptables -I OUTPUT 1 -o tailscale0 -j ACCEPT
